---
interface Props {
  name: string;
  repo: string;
  description: string;
  tags?: string[];
  language?: string;
  image?: string;
}
const { name, repo, description, tags = [], language, image } = Astro.props;
const fallback = `/images/projects/_placeholder.svg`;
const withBase = (path: string) => {
  if (!path.startsWith('/')) return path;
  const base = import.meta.env.BASE_URL;
  if (path === '/') return `${base}${base.endsWith('/') ? '' : '/'}`;
  const rest = path === '/' ? '' : path.slice(1);
  return `${base}${base.endsWith('/') || !rest ? '' : '/'}${rest}`;
};
const imageSrc = withBase(image ?? fallback);
---

<a
  href={repo}
  class="group flex flex-col rounded-xl border border-stone-200 dark:border-stone-800 bg-white dark:bg-stone-900 overflow-hidden hover:border-accent dark:hover:border-accent-d hover:shadow-md transition no-underline"
>
  <div class="aspect-[16/9] w-full overflow-hidden bg-white dark:bg-stone-900">
    <img
      src={imageSrc}
      alt={`${name} preview`}
      loading="lazy"
      class="w-full h-full object-contain group-hover:scale-[1.02] transition-transform duration-300"
    />
  </div>
  <div class="p-4 flex-1 flex flex-col">
    <div class="flex items-center justify-between gap-2">
      <h3 class="font-serif text-lg font-semibold text-stone-900 dark:text-stone-100 group-hover:text-accent dark:group-hover:text-accent-d">{name}</h3>
      {language && <span class="text-xs text-stone-400 dark:text-stone-500 shrink-0">{language}</span>}
    </div>
    <p class="text-sm text-stone-600 dark:text-stone-300 mt-1.5 leading-snug flex-1">{description}</p>
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mt-3">
        {tags.map((t) => (
          <span class="text-xs px-2 py-0.5 rounded bg-stone-100 dark:bg-stone-800 text-stone-600 dark:text-stone-300">{t}</span>
        ))}
      </div>
    )}
  </div>
</a>
