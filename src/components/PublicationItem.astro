---
interface Props {
  title: string;
  authors: string;
  venue: string;
  year: number;
  doi?: string;
  pdf?: string;
  code?: string;
  correspondingAuthors?: string[];
}
const { title, authors, venue, doi, pdf, code, correspondingAuthors = [] } = Astro.props;

const authorList = authors.split(';').map((author) => author.trim()).filter(Boolean);
const normalise = (value: string) => value.toLowerCase().replace(/[\s,.-]/g, '');
const xiangMaNames = new Set(['maxiang', 'xiangma']);
const correspondingSet = new Set(correspondingAuthors.map(normalise));
const isXiangMa = (author: string) => xiangMaNames.has(normalise(author));
const isCorresponding = (author: string) => correspondingSet.has(normalise(author));
---

<li class="py-3 first:pt-0 last:pb-0">
  <div class="text-[0.96rem] sm:text-base text-stone-900 dark:text-stone-100 leading-snug">
    {doi ? (
      <a href={`https://doi.org/${doi}`} class="text-stone-900 dark:text-stone-100 hover:text-accent dark:hover:text-accent-d no-underline hover:underline">
        {title}
      </a>
    ) : (
      title
    )}
  </div>
  <div class="text-sm text-stone-500 dark:text-stone-400 mt-1 leading-relaxed">
    {authorList.map((author, index) => (
      <>
        <span class:list={[isXiangMa(author) && 'font-semibold text-stone-800 dark:text-stone-200']}>
          {author}
          {isCorresponding(author) && <sup class="ml-0.5">*</sup>}
        </span>
        {index < authorList.length - 1 && <span>; </span>}
      </>
    ))}
  </div>
  <div class="text-sm text-stone-500 dark:text-stone-400 italic leading-relaxed">{venue}</div>
  {(pdf || code) && (
    <div class="flex gap-3 mt-1.5 text-xs">
      {pdf && <a href={pdf} class="no-underline hover:underline">PDF</a>}
      {code && <a href={code} class="no-underline hover:underline">Code</a>}
    </div>
  )}
</li>
