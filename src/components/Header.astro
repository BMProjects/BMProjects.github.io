---
import ThemeToggle from './ThemeToggle.astro';
const withBase = (path: string) => {
  if (!path.startsWith('/')) return path;
  const base = import.meta.env.BASE_URL;
  if (path === '/') return `${base}${base.endsWith('/') ? '' : '/'}`;
  const rest = path === '/' ? '' : path.slice(1);
  return `${base}${base.endsWith('/') || !rest ? '' : '/'}${rest}`;
};
const links = [
  { href: '/#about', label: 'About' },
  { href: '/#research', label: 'Research' },
  { href: '/publications', label: 'Publications' },
  { href: '/#teaching', label: 'Teaching' },
  { href: '/#grants', label: 'Grants' },
];
---

<header class="border-b border-stone-200 dark:border-stone-800 bg-stone-50/85 dark:bg-stone-950/85 backdrop-blur sticky top-0 z-20">
  <div class="container-wide py-3.5 flex items-center justify-between">
    <a href={withBase('/')} class="font-serif text-lg font-semibold text-stone-900 dark:text-stone-100 no-underline hover:no-underline">
      Xiang Ma
    </a>
    <div class="flex items-center">
      <nav class="hidden sm:flex gap-5 text-sm">
        {links.map((l) => (
          <a href={withBase(l.href)} class="text-stone-600 dark:text-stone-400 hover:text-accent dark:hover:text-accent-d no-underline hover:no-underline">
            {l.label}
          </a>
        ))}
      </nav>
      <ThemeToggle />
    </div>
  </div>
</header>
