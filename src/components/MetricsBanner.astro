---
const metrics = [
  { value: '28', label: 'publications' },
  { value: '13+', label: 'open-source tools' },
  { value: '19+', label: 'MSc students supervised' },
  { value: '3', label: 'funded research lines' },
  { value: '1', label: 'invention patent' },
];
---

<dl class="mt-7 flex flex-wrap gap-2.5">
  {metrics.map((item) => (
    <div class="rounded-lg border border-stone-200 dark:border-stone-800 bg-white/70 dark:bg-stone-900/60 px-3 py-2.5 w-[8.5rem]">
      <dt class="text-xl font-semibold text-stone-900 dark:text-stone-100">{item.value}</dt>
      <dd class="mt-0.5 text-[0.7rem] uppercase tracking-wide leading-tight text-stone-500 dark:text-stone-400">{item.label}</dd>
    </div>
  ))}
</dl>
