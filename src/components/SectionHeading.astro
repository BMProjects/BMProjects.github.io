---
interface Props {
  id?: string;
  title: string;
  kicker?: string;
  href?: string;
  hrefLabel?: string;
}
const { id, title, kicker, href, hrefLabel } = Astro.props;
const withBase = (path: string) => {
  if (!path.startsWith('/')) return path;
  const base = import.meta.env.BASE_URL;
  if (path === '/') return `${base}${base.endsWith('/') ? '' : '/'}`;
  const rest = path === '/' ? '' : path.slice(1);
  return `${base}${base.endsWith('/') || !rest ? '' : '/'}${rest}`;
};
---

<div class="flex items-end justify-between mb-6" id={id}>
  <div>
    {kicker && <div class="text-xs uppercase tracking-widest text-stone-500 dark:text-stone-400 mb-1">{kicker}</div>}
    <h2 class="text-2xl md:text-3xl font-semibold text-stone-900 dark:text-stone-100">{title}</h2>
  </div>
  {href && (
    <a href={withBase(href)} class="text-sm text-stone-500 dark:text-stone-400 hover:text-accent dark:hover:text-accent-d no-underline whitespace-nowrap">{hrefLabel ?? 'See all →'}</a>
  )}
</div>
