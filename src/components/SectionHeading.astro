---
interface Props {
  id?: string;
  title: string;
  kicker?: string;
  href?: string;
  hrefLabel?: string;
  actionId?: string;
  actionLabel?: string;
}
const { id, title, kicker, href, hrefLabel, actionId, actionLabel } = Astro.props;
const withBase = (path: string) => {
  if (!path.startsWith('/')) return path;
  const base = import.meta.env.BASE_URL;
  if (path === '/') return `${base}${base.endsWith('/') ? '' : '/'}`;
  const rest = path === '/' ? '' : path.slice(1);
  return `${base}${base.endsWith('/') || !rest ? '' : '/'}${rest}`;
};
---

<div class="relative mb-6 text-center" id={id}>
  <div class="mx-auto">
    {kicker && <div class="text-xs uppercase tracking-widest text-stone-500 dark:text-stone-400 mb-1">{kicker}</div>}
    <h2 class="text-xl md:text-2xl font-semibold text-stone-900 dark:text-stone-100">{title}</h2>
  </div>
  {href && (
    <a href={withBase(href)} class="mt-3 inline-block text-sm text-stone-500 dark:text-stone-400 hover:text-accent dark:hover:text-accent-d no-underline whitespace-nowrap md:absolute md:right-0 md:top-1 md:mt-0">{hrefLabel ?? 'See all →'}</a>
  )}
  {actionId && (
    <button
      id={actionId}
      type="button"
      class="mt-3 text-sm text-stone-500 dark:text-stone-400 hover:text-accent dark:hover:text-accent-d whitespace-nowrap md:absolute md:right-0 md:top-1 md:mt-0"
    >
      {actionLabel ?? 'Show all'}
    </button>
  )}
</div>
