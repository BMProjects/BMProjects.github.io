---
import BaseLayout from '../layouts/BaseLayout.astro';
const homeHref = `${import.meta.env.BASE_URL}${import.meta.env.BASE_URL.endsWith('/') ? '' : '/'}`;
---

<BaseLayout title="Not found — Xiang Ma">
  <section class="bg-stone-50 dark:bg-stone-950">
    <div class="container-prose py-20">
      <h1 class="text-3xl font-semibold">404 — Page not found</h1>
      <p class="mt-3 text-stone-600 dark:text-stone-400">
        The page you were looking for does not exist. <a href={homeHref}>Back to home</a>.
      </p>
    </div>
  </section>
</BaseLayout>
