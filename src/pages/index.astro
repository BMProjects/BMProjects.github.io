---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PublicationYearGroup from '../components/PublicationYearGroup.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { bioTimeline, courses, researchDirections, supervisionHighlights } from '../data/profile';

const allPubs = await getCollection('publications');
const publications = allPubs.sort((a, b) => {
  if (b.data.year !== a.data.year) return b.data.year - a.data.year;
  return a.data.title.localeCompare(b.data.title);
});
const groupPublicationsByYear = (items: typeof publications) => {
  const grouped = items.reduce<Record<number, typeof publications>>((acc, p) => {
    (acc[p.data.year] ||= []).push(p);
    return acc;
  }, {});
  return Object.keys(grouped)
    .map(Number)
    .sort((a, b) => b - a)
    .map((year) => ({ year, items: grouped[year] }));
};
const previewPublications = publications.slice(0, 5);
const previewPublicationGroups = groupPublicationsByYear(previewPublications);
const publicationGroups = groupPublicationsByYear(publications);

const allProjects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order,
);
const projectByName = new Map(allProjects.map((p) => [p.data.name, p]));
const localProjectDescriptions: Record<string, string> = {
  'Fashion Similarity Detection Tool':
    'Clothing-target detection and visual similarity retrieval from e-commerce screenshots for apparel-brand monitoring and review.',
};

const grants = (await getCollection('grants')).sort(
  (a, b) => a.data.order - b.data.order,
);

---

<BaseLayout>
  {/* ---------- About ---------- */}
  <section id="about" class="bg-stone-50 dark:bg-stone-950">
    <div class="container-wide py-12 md:py-16">
      <div class="text-xs uppercase tracking-widest text-accent dark:text-accent-d mb-3">
        Lecturer · China Jiliang University
      </div>
      <h1 class="text-3xl md:text-4xl font-semibold leading-tight">Xiang Ma</h1>

      <p class="mt-5 max-w-4xl leading-relaxed text-[0.98rem] sm:text-base text-stone-800 dark:text-stone-200">
        I am a lecturer in Computer Science at China Jiliang University. I build
        measurement and learning systems across
        <strong>medical and optical metrology</strong>,
        <strong>human-computer interaction</strong>, and
        <strong>machine learning for energy and quality systems</strong>. I like
        work with a real instrument, a real dataset, and a prototype that people
        can actually run.
      </p>

      <div class="mt-7 max-w-4xl">
        <div class="text-xs uppercase tracking-widest text-stone-500 dark:text-stone-400 mb-2">Bio</div>
        <ol class="space-y-2">
          {bioTimeline.map((item) => (
            <li class="grid grid-cols-[5.5rem_1fr] gap-3 text-sm text-stone-800 dark:text-stone-200">
              <span class="font-mono text-xs text-stone-500 dark:text-stone-400 pt-0.5">{item.period}</span>
              <span>{item.text}</span>
            </li>
          ))}
        </ol>
      </div>

      <div class="mt-7 text-sm text-stone-600 dark:text-stone-400 flex flex-wrap gap-x-6 gap-y-2">
        <span><span class="text-stone-400 dark:text-stone-500">Email · </span><a href="mailto:maxiang@cjlu.edu.cn">maxiang@cjlu.edu.cn</a></span>
        <span><span class="text-stone-400 dark:text-stone-500">GitHub · </span><a href="https://github.com/BMProjects">BMProjects</a></span>
        <span><span class="text-stone-400 dark:text-stone-500">LinkedIn · </span><a href="https://www.linkedin.com/in/xiang-ma-05ab2b318">xiang-ma</a></span>
      </div>
    </div>
  </section>

  {/* ---------- Research + Projects (merged) ---------- */}
  <section id="research" class="bg-sky-50/60 dark:bg-sky-950/20 border-y border-sky-100 dark:border-sky-950/40">
    <div class="container-wide py-12 md:py-16">
      <SectionHeading kicker="Research" title="Work by Direction" />

      {researchDirections.map((area) => {
        const items = area.projects
          .flatMap((name) => {
            const project = projectByName.get(name);
            return project ? [project] : [];
          });
        const externalItems = area.projects.filter((name) => !projectByName.has(name));
        const hasProjectItems = items.length > 0 || externalItems.length > 0;
        return (
          <section class="mb-14 last:mb-0">
            <h3 class="text-xl md:text-2xl font-semibold text-stone-900 dark:text-stone-100">{area.title}</h3>
            <p class="text-sm text-stone-600 dark:text-stone-400 mt-1 mb-5">{area.summary}</p>

            <div class:list={[
              'grid grid-cols-1 gap-6 items-start',
              hasProjectItems ? 'md:grid-cols-[1fr_18rem]' : 'md:grid-cols-[minmax(0,1fr)]',
            ]}>
              {hasProjectItems && (
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {items.map((p) => <ProjectCard {...p.data} />)}
                {externalItems.map((name) => (
                  <div class="rounded-lg border border-stone-200 dark:border-stone-800 bg-white dark:bg-stone-900 p-4">
                    <h4 class="text-lg font-semibold">{name}</h4>
                    <p class="text-sm text-stone-600 dark:text-stone-300 mt-1.5">
                      {localProjectDescriptions[name] ?? 'Applied software or supervised project recorded in local project materials.'}
                    </p>
                  </div>
                ))}
              </div>
              )}

              <div class="space-y-5 text-sm">
                <div>
                  <div class="text-xs uppercase tracking-widest text-stone-500 dark:text-stone-400 mb-2">Selected Work</div>
                  <ul class="space-y-2 text-stone-700 dark:text-stone-300">
                    {area.evidence.map((item) => <li class="border-l border-sky-300 dark:border-sky-800 pl-3">{item}</li>)}
                  </ul>
                </div>
                {area.grants.length > 0 && (
                  <div>
                    <div class="text-xs uppercase tracking-widest text-stone-500 dark:text-stone-400 mb-2">Funding</div>
                    <ul class="space-y-2 text-stone-700 dark:text-stone-300">
                      {area.grants.map((item) => <li>{item}</li>)}
                    </ul>
                  </div>
                )}
                <div>
                  <div class="text-xs uppercase tracking-widest text-stone-500 dark:text-stone-400 mb-2">Courses</div>
                  <div class="text-stone-700 dark:text-stone-300">{area.courses.join(' · ')}</div>
                </div>
              </div>
            </div>
          </section>
        );
      })}
    </div>
  </section>

  {/* ---------- Publications ---------- */}
  <section id="publications" class="bg-stone-50 dark:bg-stone-950">
    <div class="container-wide py-12 md:py-16">
      <SectionHeading kicker="Selected" title="Publications" />
      <div
        id="publication-preview"
        class="relative cursor-pointer rounded-lg -mx-3 px-3 py-1 transition hover:bg-stone-100 dark:hover:bg-stone-900"
        role="button"
        tabindex="0"
        aria-controls="publications-modal"
        aria-expanded="false"
      >
        {previewPublicationGroups.map((group, index) => (
          <PublicationYearGroup year={group.year} items={group.items} first={index === 0} />
        ))}
        <div
          class="pointer-events-none absolute inset-x-0 bottom-0 h-16 bg-gradient-to-b from-stone-50/0 to-stone-50 dark:from-stone-950/0 dark:to-stone-950"
          aria-hidden="true"
        />
      </div>
    </div>

    <div id="publications-modal" class="fixed inset-0 z-50 hidden" role="dialog" aria-modal="true" aria-labelledby="publications-modal-title">
      <button
        id="publications-modal-backdrop"
        type="button"
        class="absolute inset-0 bg-stone-950/45 backdrop-blur-sm"
        aria-label="Close publications"
      ></button>
      <div class="relative mx-auto flex min-h-full w-full max-w-5xl items-end sm:items-center justify-center px-0 sm:px-6 py-0 sm:py-8">
        <div
          id="publications-modal-panel"
          class="relative max-h-[92vh] w-full cursor-pointer overflow-hidden rounded-t-lg sm:rounded-lg border border-stone-200 dark:border-stone-800 bg-stone-50 dark:bg-stone-950 shadow-2xl"
          role="button"
          tabindex="0"
        >
          <div class="sticky top-0 z-10 border-b border-stone-200 dark:border-stone-800 bg-stone-50/95 dark:bg-stone-950/95 px-5 sm:px-7 py-4 backdrop-blur">
            <div>
              <div class="text-xs uppercase tracking-widest text-stone-500 dark:text-stone-400">All Publications</div>
              <h3 id="publications-modal-title" class="text-lg font-semibold text-stone-900 dark:text-stone-100">Publications</h3>
            </div>
          </div>
          <div class="max-h-[calc(92vh-4.75rem)] overflow-y-auto px-5 sm:px-7 py-6">
            {publicationGroups.map((group, index) => (
              <PublicationYearGroup year={group.year} items={group.items} first={index === 0} />
            ))}
          </div>
        </div>
      </div>
    </div>

    <script>
      const publicationPreview = document.querySelector('#publication-preview');
      const modalBackdrop = document.querySelector('#publications-modal-backdrop');
      const publicationsModal = document.querySelector('#publications-modal');
      const publicationsModalPanel = document.querySelector('#publications-modal-panel');

      const setModalOpen = (open) => {
        if (!(publicationsModal instanceof HTMLElement)) return;
        publicationsModal.classList.toggle('hidden', !open);
        document.documentElement.classList.toggle('overflow-hidden', open);
        publicationPreview?.setAttribute('aria-expanded', String(open));
      };

      publicationPreview?.addEventListener('click', (event) => {
        if (event.target instanceof Element && event.target.closest('a')) return;
        setModalOpen(true);
      });
      publicationPreview?.addEventListener('keydown', (event) => {
        if (!(event instanceof KeyboardEvent)) return;
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          setModalOpen(true);
        }
      });
      publicationsModalPanel?.addEventListener('click', (event) => {
        if (event.target instanceof Element && event.target.closest('a')) return;
        setModalOpen(false);
      });
      publicationsModalPanel?.addEventListener('keydown', (event) => {
        if (!(event instanceof KeyboardEvent)) return;
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          setModalOpen(false);
        }
      });
      modalBackdrop?.addEventListener('click', () => setModalOpen(false));
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') setModalOpen(false);
      });
    </script>
  </section>

  {/* ---------- Teaching ---------- */}
  <section id="teaching" class="bg-amber-50/60 dark:bg-amber-950/15 border-y border-amber-100 dark:border-amber-950/40">
    <div class="container-wide py-12 md:py-16">
      <SectionHeading kicker="Courses & Supervision" title="Teaching" />
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-6 divide-y md:divide-y-0 divide-amber-200/60 dark:divide-amber-900/40">
        {courses.map((c) => (
          <li class="py-3 text-stone-800 dark:text-stone-200 border-b border-amber-200/60 dark:border-amber-900/40">
            <div class="flex justify-between gap-4">
              <span class="font-medium">{c.name}</span>
              <span class="text-sm text-stone-500 dark:text-stone-400 shrink-0">{c.years}</span>
            </div>
            <p class="text-sm text-stone-600 dark:text-stone-400 mt-1">{c.features}</p>
          </li>
        ))}
      </ul>
      <div class="mt-6 grid grid-cols-1 md:grid-cols-3 gap-4 text-sm text-stone-700 dark:text-stone-300">
        {supervisionHighlights.map((item) => (
          <div class="border-t border-amber-300 dark:border-amber-800 pt-3">{item}</div>
        ))}
      </div>
    </div>
  </section>

  {/* ---------- Grants ---------- */}
  <section id="grants" class="bg-emerald-50/60 dark:bg-emerald-950/15">
    <div class="container-wide py-12 md:py-16">
      <SectionHeading kicker="Funding" title="Research Grants" />
      <ul class="grid grid-cols-1 lg:grid-cols-2 gap-x-8 gap-y-5">
        {grants.map((g) => (
          <li>
            <div class="text-stone-900 dark:text-stone-100">{g.data.title}</div>
            <div class="text-sm text-stone-500 dark:text-stone-400 mt-0.5">
              {g.data.funder} · {g.data.amount} · {g.data.role} · {g.data.start} – {g.data.end}
              {g.data.status && <> · {g.data.status}</>}
            </div>
            {g.data.description && (
              <p class="text-sm text-stone-700 dark:text-stone-300 mt-1.5">{g.data.description}</p>
            )}
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>
