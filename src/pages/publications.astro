---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PublicationItem from '../components/PublicationItem.astro';

const pubs = (await getCollection('publications')).sort(
  (a, b) => b.data.year - a.data.year,
);

const byYear = pubs.reduce<Record<number, typeof pubs>>((acc, p) => {
  (acc[p.data.year] ||= []).push(p);
  return acc;
}, {});

const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);
---

<BaseLayout title="Publications — Xiang Ma">
  <section class="bg-stone-50 dark:bg-stone-950">
    <div class="container-prose py-14 md:py-20">
      <h1 class="text-3xl md:text-4xl font-semibold">Publications</h1>

      {years.map((y) => (
        <div class="mt-10">
          <SectionHeading title={String(y)} />
          <ol>
            {byYear[y].map((p) => <PublicationItem {...p.data} showYear={false} />)}
          </ol>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
